# ============================================================================
# LLM CONFIGURATION (OpenAI-compatible)
# ============================================================================

# Core settings
LLM_MODEL=gpt-5.2
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=${OPENAI_API_KEY}

# Examples (OpenAI cloud)
# LLM_MODEL=gpt-5.2
# LLM_MODEL=gpt-4o-mini

# Examples (Ollama local - OpenAI compatible)
# LLM_MODEL=llama3.2:1b-instruct-q5_K_M
# LLM_MODEL=qwen2.5:14b-instruct-q4_K_M
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=not-needed

# ============================================================================
# LLM GENERATION PARAMETERS
# ============================================================================
# Note: Some parameters may not apply to reasoning models (o1, o3-mini).
# These models have restricted parameter support and may ignore certain settings.

# Temperature: 0.0 = deterministic/factual, 1.0 = creative, 2.0 = very creative
# Not supported by reasoning models (o1, o3-mini)
LLM_TEMPERATURE=0.0

# Max tokens in response (controls response length and costs)
# Reasoning models use max_completion_tokens instead
LLM_MAX_TOKENS=500

# Optional: reasoning effort for compatible models (e.g., "low", "medium", "high")
# LLM_REASONING_EFFORT=high

# Timeout in seconds for LLM API requests
LLM_TIMEOUT=100.0

# Maximum number of retry attempts (0 = no retries, 3 = default)
LLM_MAX_RETRIES=3

# Exponential backoff multiplier for retries (wait time = factor^attempt)
# Example: factor=2.0 means 1s, 2s, 4s, 8s wait times
LLM_RETRY_BACKOFF_FACTOR=2.0

# ============================================================================
# PERFORMANCE SETTINGS
# ============================================================================

# Maximum number of LLM sections to generate concurrently (1-10)
# Higher values = faster generation but more API load
MAX_PARALLEL_LLM_SECTIONS=1

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: 'simple' for human-readable, 'json' for structured logging
LOG_FORMAT=simple
