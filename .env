LLM_API_KEY=${OPENAI_API_KEY}
LLM_BASE_URL=https://api.openai.com/v1
LLM_DEBUG_JSON_DIR=out/debug/llm
LLM_DEBUG_JSON_ENABLED=true
LLM_INPUT_COST_PER_MILLION_TOKENS=2.50
LLM_MAX_CONCURRENCY=8
LLM_MAX_RETRIES=3
LLM_MODEL=gpt-5.2
LLM_OUTPUT_COST_PER_MILLION_TOKENS=15.00
LLM_RETRY_BACKOFF_FACTOR=2.0
LLM_TIMEOUT=100.0
LOG_FORMAT=simple
LOG_LEVEL=INFO
MODEL_DEBUG_JSON_DIR=out/debug/models
MODEL_DEBUG_JSON_ENABLED=true
